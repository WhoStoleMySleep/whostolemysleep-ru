// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  name     String?
  password String?
  date     DateTime? @updatedAt
}

model Products {
  id         Int      @id @default(autoincrement())
  type       String
  title      String
  text       String
  text_short String
  author     String?
  url        String?
  tags       Tags[]
  images     Images[]
  date       DateTime @updatedAt
}

model Tags {
  id         Int       @id @default(autoincrement())
  product_id Int?
  product    Products? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  name       String
  date       DateTime  @updatedAt
}

model Images {
  id         Int       @id @default(autoincrement())
  product_id Int?
  product    Products? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  url        String?
  alt        String?
  date       DateTime  @updatedAt
}

model AboutMe {
  id   Int      @id @default(autoincrement())
  text String
  date DateTime @updatedAt
}

model Inform {
  id            Int             @id @default(autoincrement())
  title         String
  type          String
  place         String
  dateString    String
  InformDetails InformDetails[]
  date          DateTime        @updatedAt
}

model InformDetails {
  id       Int      @id @default(autoincrement())
  text     String
  date     DateTime @updatedAt
  Inform   Inform?  @relation(fields: [informId], references: [id], onDelete: SetNull)
  informId Int?
}

model Skills {
  id          Int      @id @default(autoincrement())
  languages   String
  frameworks  String
  cms         String
  instruments String
  date        DateTime @updatedAt
}
